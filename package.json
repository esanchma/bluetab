{
  "name": "@esanchma/bluetab",
  "version": "0.1.1",
  "description": "Minimal MV3 brotab-like tab CLI for Chromium browsers.",
  "type": "module",
  "bin": {
    "bt": "./cli/bt.js"
  },
  "files": [
    "cli/",
    "src/",
    "scripts/",
    "extension/",
    "native-host.example.json",
    "README.md"
  ],
  "scripts": {
    "check": "tsc --noEmit",
    "build": "bun build ./src/main.ts --compile --outfile ./dist/bt",
    "pack:extension": "node ./scripts/pack-extension.js",
    "prepack": "bun run check"
  },
  "keywords": [
    "brotab",
    "browser-tabs",
    "chromium",
    "brave",
    "native-messaging",
    "mv3"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "bun": "^1.3.14"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "latest"
  }
}
